# 複製此檔為「.env」並放在 exe 同目錄（輸出目錄），再依需求修改。
#
# carrier：載具條碼（載具生成器2.html）
# name_label：姓名貼（中文軟鍵盤 + TSC TTP-345）
APP_MODE=name_label

# Windows「印表機與掃描器」顯示的印表機名稱（需與驅動完全一致）
TSC_WINDOWS_PRINTER_NAME=TSC TTP-345

# 標籤解析度（多數 TTP-345 為 300）
TSC_DPI=300

# 標籤尺寸（毫米）
LABEL_WIDTH_MM=50
LABEL_HEIGHT_MM=30

# 紙張間隙（毫米；連續紙可改 0）
LABEL_GAP_MM=2
# 紙張感應模式：gap / blackmark / continuous
TSC_PAPER_SENSOR_MODE=gap
# 黑標高度（毫米；僅 blackmark 模式使用）
TSC_BLACK_MARK_MM=2
# 黑標感應後，裁切前額外走紙步數（dots）
TSC_BLACK_MARK_POST_FEED_STEPS=0

# 姓名貼排版：3 欄 x 6 列，格與格間距 5mm
NAME_LABEL_COLUMNS=3
NAME_LABEL_ROWS=6
NAME_LABEL_CELL_GAP_MM=5
# 欄距 / 列距可分開調整（若有設定，優先於 NAME_LABEL_CELL_GAP_MM）
NAME_LABEL_COLUMN_GAP_MM=5
NAME_LABEL_ROW_GAP_MM=5
# 姓名貼排版使用高度（毫米）。0=使用整張高度；可用來縮短上下列距。
NAME_LABEL_GRID_HEIGHT_MM=0
# 姓名貼整體比例（字體 + 間距一起縮放），可設範圍：0.001 ~ 2.0
NAME_LABEL_LAYOUT_SCALE=1.0
# 文字字元間距（像素）。正值加大、負值縮小。可設範圍：-200 ~ 200
NAME_LABEL_CHAR_SPACING_PX=0
# 第一欄文字水平位移（像素）。正值往右、負值往左。
NAME_LABEL_FIRST_COLUMN_OFFSET_X_PX=0
# 各欄文字水平位移（像素，逗號分隔）。例如：30,-5,10
NAME_LABEL_COLUMN_OFFSETS_X_PX=0,0,0

# 姓名貼輸出模式：
# auto   = 英數用 TEXT、中文自動 BITMAP
# text   = 強制純 TEXT（只出字體；需印表機有中文字型）
# bitmap = 強制 BITMAP
NAME_LABEL_PRINT_MODE=auto
NAME_LABEL_TSPL_FONT=TSS24.BF2
# BITMAP 模式優先使用的 Windows 字型家族（鍵盤頁面可臨時覆蓋）
NAME_LABEL_BITMAP_FONT_FAMILY=Microsoft JhengHei
NAME_LABEL_ROTATE_180=false
TSC_SPEED=2
TSC_DENSITY=5
# 若機型/韌體支援，可打開以下兩項做編碼指定
TSC_CODEPAGE=UTF-8
TSC_CHARSET=UTF-8
# BITMAP 二值化與加粗（先用保守值）
BITMAP_THRESHOLD=200
BITMAP_BOLD_PX=0
# 除錯：將送印前 BITMAP 存成 PNG（檢查是否已含黑線）
DEBUG_SAVE_BITMAP=false
DEBUG_BITMAP_PATH=C:\test_label.png

# 純文字中文建議（TTP-345 常見可用組合）
# NAME_LABEL_PRINT_MODE=text
# NAME_LABEL_TSPL_FONT=TST24.BF2
# TSC_CODEPAGE=950
# TSC_CHARSET=BIG5

# 是否在每次姓名貼列印後裁切（需有安裝裁刀）
# 可用值：true / false（或 1 / 0）
TSC_CUT_AFTER_PRINT=false
